# Contact form — set ONE of the following (restart `npm run dev` after changing)

# Option A — Formspree: https://formspree.io → New Form → copy POST URL
# VITE_CONTACT_FORM_URL=https://formspree.io/f/xxxxxxxx

# Option B — Web3Forms: https://web3forms.com → create form → copy Access Key
# VITE_WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
